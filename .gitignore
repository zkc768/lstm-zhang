# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Notebook runtime noise
.ipynb_checkpoints/
notebooks/*_run_all*.ipynb
notebooks/*_full_run*.ipynb
notebooks/*.bak*

# Raw data and generated outputs
data/raw/
data/interim/
data/processed/
results/**
!results/.gitkeep
!results/lst_models/.gitkeep
artifacts/**
!artifacts/.gitkeep

# Model/checkpoint outputs
/models/
checkpoints/
*.pt
*.pth
*.ckpt
*.pkl
*.joblib

# Local env files
.env
.venv/
venv/

# AI-facing docs
#
# Keep route-critical docs visible to GitHub/Colab agents. Ignore ad hoc docs
# by default, then un-ignore the project contracts and all protocol sidecars.
docs/*
!docs/protocols/
!docs/protocols/**
!docs/agent_capabilities_and_skill_routing.md
!docs/lst_models_code_style_and_route_guide.md
!docs/lst_models_google_drive_raw_data_guide.md
!docs/lst_models_paper_translation_and_anti_ai_style_guide.md
!docs/lst_models_paper_narrative_and_template_papers_guide.md
!docs/lst_models_paper_format_and_figures_contract.md
!docs/adr/
!docs/adr/**

# Local paper workspace (Doc A contract: local-only), EXCEPT the gate toolchain
# under paper/scripts/, shared so the QC workflow is reproducible across
# clones/Colab/agents (submission_qc_matrix.md Persistence; P1-a user decision).
# Drafts, sections, length_loop runs, and references stay local-only.
paper/*
!paper/scripts/
paper/scripts/*
!paper/scripts/*.py

# Local Claude Code tooling state (machine-local; not shared). If a shared
# config is ever added, un-ignore it explicitly, e.g. !.claude/settings.json
.claude/

# paper rollback baseline (added 2026-06-28, ADR 0003)
tmp/
tmp_err.txt
tmp_old09.txt
__pycache__/
*.pyc
paper_compare/exemplars/pdfs/

# LaTeX build byproducts in the paper_compare sandbox -- regenerated on every
# compile, untracked 2026-07-01 (keeps the ADR 0003 v2 sandbox clean). The
# _section_backups/*.bak rollback snapshots are intentional and stay tracked.
paper_compare/**/*.aux
paper_compare/**/*.blg
paper_compare/**/*.fls
paper_compare/**/*.fdb_latexmk
paper_compare/**/*.out
paper_compare/**/*.log
